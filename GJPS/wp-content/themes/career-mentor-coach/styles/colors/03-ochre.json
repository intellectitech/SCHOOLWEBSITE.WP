{
  "$schema": "https://schemas.wp.org/wp/6.8/theme.json",
  "version": 3,
  "title": "Ochre",
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary",         "color": "#A58317", "name": "Primary" },
        { "slug": "primary-dark",    "color": "#67520E", "name": "Primary Dark" },
        { "slug": "primary-light",   "color": "#B08C19", "name": "Primary Light" },
        { "slug": "primary-soft",    "color": "#F9F1D7", "name": "Primary Soft" },
        { "slug": "heading-text",    "color": "#2A261E", "name": "Text Dark" },
        { "slug": "paragraph-text",  "color": "#5C5342", "name": "Text Light" },
        { "slug": "muted-text",      "color": "#7D7668", "name": "Muted Text" },
        { "slug": "white",           "color": "#FFFFFF", "name": "White" },
        { "slug": "background-light","color": "#FFFAF0", "name": "Background Light" },
        { "slug": "background-dark", "color": "#FFF7E5", "name": "Background Dark" },
        { "slug": "border",          "color": "#EEEADD", "name": "Border" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background-light)",
      "text": "var(--wp--preset--color--heading-text)"
    },
    "elements": {
      "h1": { "color": { "text": "var(--wp--preset--color--heading-text)" } },
      "h2": { "color": { "text": "var(--wp--preset--color--heading-text)" } },
      "h3": { "color": { "text": "var(--wp--preset--color--heading-text)" } },
      "link": { "color": { "text": "var(--wp--preset--color--primary)" } },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-dark)",
            "text": "var(--wp--preset--color--white)"
          }
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "var:preset|color|primary",
          "text": "var:preset|color|white"
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|primary-dark",
            "text": "var:preset|color|white"
          }
        }
      }
    },
    "border": {
      "color": "var:preset|color|border"
    }
  }
}
